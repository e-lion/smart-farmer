rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Records (Income/Expenses)
    match /records/{recordId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow creating/updating with basic validation
      allow create, update: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount >= 0;
    }

    // Educational Modules
    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      
      // Recommendation: For production, seed data server-side or via an admin dashboard.
      // General users should NOT have write access to shared education content.
      // Temporarily allowing 'create' for idempotent seeding, but 'update/delete' is restricted.
      allow create: if isAuthenticated();
      allow update, delete: if false; 
    }
  }
}
